{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/hud/**",
              "ui_kits/app/**",
              "ui_kits/overlay/**",
              "ui_kits/shared/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Chakra Petch|Manrope|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Chakra Petch, Manrope, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|solid|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, solid, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|gold|blue|red|green)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'gold' | 'blue' | 'red' | 'green'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|fullWidth|disabled|iconLeft|iconRight|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, fullWidth, disabled, iconLeft, iconRight, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|padding|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|inset|overlay)$/]",
        "message": "<Card> variant must be one of 'default' | 'inset' | 'overlay'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|children|icon|actions|onDismiss|width|style|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, title, children, icon, actions, onDismiss, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IVStat'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|max|style|key|ref|className|style|children)$/]",
        "message": "<IVStat> doesn't accept that prop. Declared props: label, value, max, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|description|trailing|leading|onClick|divider|style|key|ref|className|style|children)$/]",
        "message": "<ListRow> doesn't accept that prop. Declared props: label, description, trailing, leading, onClick, divider, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MoveChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|name|count|recommended|style|key|ref|className|style|children)$/]",
        "message": "<MoveChip> doesn't accept that prop. Declared props: kind, name, count, recommended, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MoveChip'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:fast|charged)$/]",
        "message": "<MoveChip> kind must be one of 'fast' | 'charged'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RankBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:league|rank|total|percent|style|key|ref|className|style|children)$/]",
        "message": "<RankBadge> doesn't accept that prop. Declared props: league, rank, total, percent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|disabled|onChange|id|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, disabled, onChange, id."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
