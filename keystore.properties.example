# Copy this file to `keystore.properties` (gitignored) and fill in your values.
# First create the upload keystore (keep it somewhere safe and BACK IT UP — losing it
# means you can't update the app):
#
#   keytool -genkeypair -v -keystore pvpeek-upload.jks -alias pvpeek \
#           -keyalg RSA -keysize 2048 -validity 10000
#
# Then point storeFile at that .jks and fill in the passwords you chose.

storeFile=/absolute/path/to/pvpeek-upload.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=pvpeek
keyPassword=YOUR_KEY_PASSWORD
